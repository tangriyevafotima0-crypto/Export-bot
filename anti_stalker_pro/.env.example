# =============================================================================
# Anti-Stalker Intelligence System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Telegram Credentials ---
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram numeric user ID (for notifications)
MY_TELEGRAM_ID=

# --- Dashboard Configuration ---
# Secret key for JWT token signing (REQUIRED: generate a strong random string)
# WARNING: The system will log a security warning if this is left as the default
DASHBOARD_SECRET_KEY=change-me-to-a-random-secret

# Dashboard port
DASHBOARD_PORT=8080

# Dashboard host binding
DASHBOARD_HOST=0.0.0.0

# --- Trap Server Configuration ---
# URL that tracking links will redirect to after capturing visitor info
TRACKING_REDIRECT_URL=https://www.google.com

# Flask trap server port
TRAP_SERVER_PORT=5000

# Flask trap server host
TRAP_SERVER_HOST=0.0.0.0

# --- Database ---
# SQLite async database URL
DATABASE_URL=sqlite+aiosqlite:///data/anti_stalker.db

# --- Monitoring Intervals (seconds) ---
# How often to check online status
ONLINE_CHECK_INTERVAL=30

# How often to check stories
STORY_CHECK_INTERVAL=60

# How often to run pattern analysis
ANALYSIS_INTERVAL=3600

# --- Scoring Thresholds ---
# Suspicion score threshold for alerts (0-100)
ALERT_THRESHOLD=70

# Maximum tracked users
MAX_TRACKED_USERS=50

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
